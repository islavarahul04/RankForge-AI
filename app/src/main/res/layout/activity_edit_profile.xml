<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FE"
    tools:context=".EditProfileActivity">

    <!-- Top Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_section"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="24dp"
            android:background="@drawable/bg_circle_profile"
            android:backgroundTint="#F0F2F5"
            android:padding="8dp"
            android:src="@drawable/ic_chevron_left"
            app:tint="#101820"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Edit Profile"
            android:textColor="#101820"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="parent" />
            
            <TextView
                android:id="@+id/tv_action_save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="Save"
                android:textColor="#FF8C00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:paddingBottom="40dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_section">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- Avatar Section -->
            <FrameLayout
                android:id="@+id/fl_avatar_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clickable="true"
                android:focusable="true">

                <!-- Inner Circle JD -->
                <TextView
                    android:id="@+id/tv_avatar"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_circle_profile"
                    android:gravity="center"
                    android:text="JD"
                    android:textColor="#3A4D66"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <!-- Target Image View -->
                <androidx.cardview.widget.CardView
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    app:cardCornerRadius="48dp"
                    app:cardElevation="0dp"
                    android:backgroundTint="@android:color/transparent">
                    
                    <ImageView
                        android:id="@+id/iv_avatar_image"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />
                </androidx.cardview.widget.CardView>

                <!-- Outer Circle Ring -->
                <View
                    android:layout_width="104dp"
                    android:layout_height="104dp"
                    android:layout_gravity="center"
                    android:background="@drawable/ic_circle_outline"
                    android:backgroundTint="#FFFFFF"
                    android:elevation="2dp" />

                <!-- Camera Orange Icon -->
                <ImageView
                    android:id="@+id/iv_camera"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginBottom="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_circle_orange"
                    android:elevation="4dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_gallery"
                    app:tint="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Change Photo"
                android:textColor="#FF8C00"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Input Form -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="vertical">

                <!-- Full Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Name"
                    android:textColor="#5A6B80"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/et_full_name"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext"
                    android:hint="Full Name"
                    android:text=""
                    android:textColor="#101820"
                    android:textColorHint="#8C98A4"
                    android:textSize="14sp"
                    android:paddingHorizontal="16dp"
                    android:inputType="textPersonName" />

                <!-- Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Email"
                    android:textColor="#5A6B80"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext"
                    android:hint="Email Address"
                    android:text=""
                    android:textColor="#101820"
                    android:textColorHint="#8C98A4"
                    android:textSize="14sp"
                    android:paddingHorizontal="16dp"
                    android:enabled="false"
                    android:inputType="textEmailAddress" />

                <!-- Phone Number -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Phone Number"
                    android:textColor="#5A6B80"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <EditText
                        android:id="@+id/et_phone"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_edittext"
                        android:hint="Phone Number"
                        android:text=""
                        android:textColor="#101820"
                        android:textColorHint="#8C98A4"
                        android:textSize="14sp"
                        android:paddingHorizontal="16dp"
                        android:inputType="phone" />

                    <TextView
                        android:id="@+id/btn_change_phone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="16dp"
                        android:text="Change"
                        android:textColor="#FF8C00"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <!-- Date of Birth & City Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <!-- DOB -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Date of Birth"
                            android:textColor="#5A6B80"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                        
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp">
                            <EditText
                                android:id="@+id/et_dob"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:background="@drawable/bg_edittext"
                                android:hint="YYYY-MM-DD"
                                android:text=""
                                android:textColor="#101820"
                                android:textSize="14sp"
                                android:paddingStart="16dp"
                                android:paddingEnd="48dp"
                                android:focusable="false"
                                android:cursorVisible="false" />
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="end|center_vertical"
                                android:layout_marginEnd="16dp"
                                android:src="@drawable/ic_calendar_blue"
                                app:tint="#8C98A4" />
                        </FrameLayout>
                    </LinearLayout>

                    <!-- City -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="City"
                            android:textColor="#5A6B80"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                        
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp">
                            <EditText
                                android:id="@+id/et_city"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:background="@drawable/bg_edittext"
                                android:hint="City"
                                android:text=""
                                android:textColor="#101820"
                                android:textSize="14sp"
                                android:paddingStart="16dp"
                                android:paddingEnd="48dp" />
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="end|center_vertical"
                                android:layout_marginEnd="16dp"
                                android:src="@drawable/ic_map_teal"
                                app:tint="#8C98A4" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Gender -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Gender"
                    android:textColor="#5A6B80"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                
                <RadioGroup
                    android:id="@+id/rg_gender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:checkedButton="@+id/rb_male">

                    <RadioButton
                        android:id="@+id/rb_male"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="#FF8C00"
                        android:text="Male"
                        android:textColor="#101820"
                        android:textSize="14sp" />

                    <RadioButton
                        android:id="@+id/rb_female"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:buttonTint="#8C98A4"
                        android:text="Female"
                        android:textColor="#101820"
                        android:textSize="14sp" />

                    <RadioButton
                        android:id="@+id/rb_other"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:buttonTint="#8C98A4"
                        android:text="Other"
                        android:textColor="#101820"
                        android:textSize="14sp" />
                </RadioGroup>

                <!-- Target Exam -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Target Exam"
                    android:textColor="#5A6B80"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                
                <!-- Use Spinner with custom back arrow to simulate bounded dropdown -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext">
                    
                    <Spinner
                        android:id="@+id/spinner_target_exam"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:paddingStart="16dp"
                        android:theme="@style/Theme.AppCompat.Light"/>
                        
                    <!-- Dropdown Arrow Indicator -->
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_chevron_right_small"
                        android:rotation="90" 
                        app:tint="#8C98A4" />
                </FrameLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
    
</androidx.constraintlayout.widget.ConstraintLayout>
