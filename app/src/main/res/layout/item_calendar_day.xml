<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <TextView
        android:id="@+id/tv_day_number"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_circle_day_inactive"
        android:gravity="center"
        tools:text="1"
        android:textColor="#101820"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_fire_overlay"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_circle_gradient_orange"
        android:padding="8dp"
        android:src="@drawable/ic_fire_modern"
        android:visibility="gone"
        app:tint="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="@id/tv_day_number"
        app:layout_constraintEnd_toEndOf="@id/tv_day_number"
        app:layout_constraintStart_toStartOf="@id/tv_day_number"
        app:layout_constraintTop_toTopOf="@id/tv_day_number" />

</androidx.constraintlayout.widget.ConstraintLayout>
