<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FE"
    tools:context=".ExamConductActivity">

    <!-- Header / Top Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Top Row (Title + Timer) -->
        <LinearLayout
            android:id="@+id/ll_top_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="48dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btn_back_exam"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_circle_profile"
                android:backgroundTint="#F0F2F5"
                android:padding="8dp"
                android:src="@drawable/ic_chevron_left"
                app:tint="#101820" />

            <TextView
                android:id="@+id/tv_exam_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="SSC CHSL Tier 1"
                android:textColor="#101820"
                android:textSize="18sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Timer Box -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_white"
                android:backgroundTint="#FFF1F0"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:gravity="center_vertical">
                
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_clock"
                    app:tint="#F44336" />
                    
                <TextView
                    android:id="@+id/tv_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="59:00"
                    android:textColor="#F44336"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Section Tabs -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/ll_top_row">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tab_english"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_white"
                    android:backgroundTint="#26348B"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="English Language"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tab_intelligence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_pill_white"
                    android:backgroundTint="#F0F2F5"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="General Intelligence"
                    android:textColor="#5A6B80"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tab_quantitative"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_pill_white"
                    android:backgroundTint="#F0F2F5"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="Quantitative Aptitude"
                    android:textColor="#5A6B80"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tab_awareness"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_pill_white"
                    android:backgroundTint="#F0F2F5"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="General Awareness"
                    android:textColor="#5A6B80"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </HorizontalScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Content Area (Left/Center) -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/right_panel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <TextView
                    android:id="@+id/tv_question_index_display"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Question 1/100"
                    android:textColor="#101820"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Question Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_white_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_question_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading Question..."
                    android:textColor="#101820"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"/>

                <RadioGroup
                    android:id="@+id/rg_options"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp">

                    <RadioButton
                        android:id="@+id/rb_option_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_outline_button"
                        android:padding="16dp"
                        android:buttonTint="#26348B"
                        android:text="Option 1"
                        android:textColor="#5A6B80"
                        android:textSize="14sp" />

                    <RadioButton
                        android:id="@+id/rb_option_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_outline_button"
                        android:padding="16dp"
                        android:buttonTint="#26348B"
                        android:text="Option 2"
                        android:textColor="#5A6B80"
                        android:textSize="14sp" />

                    <RadioButton
                        android:id="@+id/rb_option_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_outline_button"
                        android:padding="16dp"
                        android:buttonTint="#26348B"
                        android:text="Option 3"
                        android:textColor="#5A6B80"
                        android:textSize="14sp" />

                    <RadioButton
                        android:id="@+id/rb_option_4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_outline_button"
                        android:padding="16dp"
                        android:buttonTint="#26348B"
                        android:text="Option 4"
                        android:textColor="#5A6B80"
                        android:textSize="14sp" />
                </RadioGroup>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Right Panel (Question Palette Drawer) -->
    <LinearLayout
        android:id="@+id/right_panel"
        android:layout_width="72dp"
        android:layout_height="0dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/bottom_action_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="Q. Palette"
            android:textColor="#8C98A4"
            android:textSize="10sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#F8F9FE"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <!-- Dynamic Buttons added here via code -->
            <LinearLayout
                android:id="@+id/ll_palette_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="16dp"
                android:gravity="center" />
        </ScrollView>
    </LinearLayout>

    <!-- Bottom Action Bar (Next/Submit) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="16dp"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            tools:ignore="MissingConstraints">
            
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_next_question"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_button_solve"
                android:backgroundTint="#FF8C00"
                android:text="Next"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_submit_exam_permanent"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_button_solve"
                android:backgroundTint="#4CAF50"
                android:text="Submit"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
