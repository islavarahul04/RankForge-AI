<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FE"
    tools:context=".NotificationsActivity">

    <!-- Top Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_section"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="24dp"
            android:background="@drawable/bg_circle_profile"
            android:backgroundTint="#F0F2F5"
            android:padding="8dp"
            android:src="@drawable/ic_chevron_left"
            app:tint="#101820"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Notifications"
            android:textColor="#101820"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_mark_read"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            android:text="Mark all read"
            android:textColor="#FF8C00"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Filter Chips -->
    <HorizontalScrollView
        android:id="@+id/scroll_filters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="24dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/header_section">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tab_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_outline_button"
                android:backgroundTint="#101820"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:text="All"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tab_tests"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_outline_button"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:text="Tests"
                android:textColor="#5A6B80"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tab_study"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_outline_button"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:text="Study"
                android:textColor="#5A6B80"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tab_community"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_outline_button"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:text="Community"
                android:textColor="#5A6B80"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tab_offers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_outline_button"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:text="Offers"
                android:textColor="#5A6B80"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Inner Scrollable List -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:paddingBottom="40dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scroll_filters">

        <LinearLayout
            android:id="@+id/notification_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- TODAY -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today"
                android:textColor="#8C98A4"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Tests Notif -->
            <LinearLayout
                android:tag="Tests"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_white_card"
                android:elevation="1dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_capsule_white"
                    android:backgroundTint="#2663E2" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_badge_dark_blue"
                    android:padding="10dp"
                    android:src="@drawable/ic_notification"
                    app:tint="#2663E2" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mock Test #9 starts in 1 hour"
                        android:textColor="#101820"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="10 min ago"
                        android:textColor="#8C98A4"
                        android:textSize="10sp" />
                </LinearLayout>

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_circle_icon"
                    android:backgroundTint="#2663E2" />
            </LinearLayout>

            <!-- Study Notif -->
            <LinearLayout
                android:tag="Study"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_white_card"
                android:elevation="1dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_capsule_white"
                    android:backgroundTint="#2663E2" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_badge_green"
                    android:backgroundTint="#F4EBFA"
                    android:padding="10dp"
                    android:src="@drawable/ic_ai_sparkles"
                    app:tint="#9C27B0" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI has updated your study plan"
                        android:textColor="#101820"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="2 hours ago"
                        android:textColor="#8C98A4"
                        android:textSize="10sp" />
                </LinearLayout>

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_circle_icon"
                    android:backgroundTint="#2663E2" />
            </LinearLayout>
            
            <!-- General Activity Notif -->
            <LinearLayout
                android:tag="Study"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_white_card"
                android:elevation="1dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_capsule_white"
                    android:backgroundTint="#FFFFFF" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_circle_orange_translucent"
                    android:padding="10dp"
                    android:src="@drawable/ic_fire_modern"
                    app:tint="#FF8C00" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="You're on a 12-day streak!"
                        android:textColor="#5A6B80"
                        android:textSize="12sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="5 hours ago"
                        android:textColor="#8C98A4"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- YESTERDAY -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Yesterday"
                android:textColor="#8C98A4"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Tests Report -->
            <LinearLayout
                android:tag="Tests"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_white_card"
                android:elevation="1dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_capsule_white"
                    android:backgroundTint="#FFFFFF" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_badge_green"
                    android:backgroundTint="#E8F5E9"
                    android:padding="10dp"
                    android:src="@drawable/ic_test_history"
                    app:tint="#4CAF50" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your weekly report is ready"
                        android:textColor="#5A6B80"
                        android:textSize="12sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Yesterday"
                        android:textColor="#8C98A4"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Community -->
            <LinearLayout
                android:tag="Community"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_white_card"
                android:elevation="1dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_capsule_white"
                    android:backgroundTint="#FFFFFF" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_badge_dark_blue"
                    android:backgroundTint="#F0F2F5"
                    android:padding="10dp"
                    android:src="@drawable/ic_send_msg"
                    app:tint="#5A6B80" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rahul replied to your discussion"
                        android:textColor="#5A6B80"
                        android:textSize="12sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Yesterday"
                        android:textColor="#8C98A4"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
            
            <!-- THIS WEEK -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="This Week"
                android:textColor="#8C98A4"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Rankings/Study -->
            <LinearLayout
                android:tag="Study"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_white_card"
                android:elevation="1dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_capsule_white"
                    android:backgroundTint="#FFFFFF" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_circle_orange_translucent"
                    android:backgroundTint="#FFF8E1"
                    android:padding="10dp"
                    android:src="@drawable/ic_target"
                    app:tint="#FFC107" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="You moved up 50 ranks!"
                        android:textColor="#5A6B80"
                        android:textSize="12sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="2 days ago"
                        android:textColor="#8C98A4"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
            
            <!-- Offers -->
            <LinearLayout
                android:tag="Offers"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_white_card"
                android:elevation="1dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_capsule_white"
                    android:backgroundTint="#FFFFFF" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_badge_green"
                    android:backgroundTint="#FFEBEE"
                    android:padding="10dp"
                    android:src="@drawable/ic_target"
                    app:tint="#F44336" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Special offer: 50% off Ultimate plan"
                        android:textColor="#5A6B80"
                        android:textSize="12sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="3 days ago"
                        android:textColor="#8C98A4"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
