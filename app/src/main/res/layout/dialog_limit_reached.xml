<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.microsoft.com/apk/res/android"
    xmlns:app="http://schemas.microsoft.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    android:background="@drawable/bg_white_card"
    android:padding="24dp">

    <ImageView
        android:id="@+id/iv_limit_icon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_circle_icon"
        android:backgroundTint="#FFF8E1"
        android:padding="16dp"
        android:src="@drawable/ic_ai_premium"
        app:tint="#FFC107"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_limit_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Limit Exhausted"
        android:textColor="#101820"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_limit_icon" />

    <TextView
        android:id="@+id/tv_limit_message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="You've reached your daily limit of 20 free chats. Upgrade to Premium for unlimited access and faster responses!"
        android:textColor="#8C98A4"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_limit_title" />

    <TextView
        android:id="@+id/btn_upgrade_premium"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_pill_orange"
        android:backgroundTint="#FF9800"
        android:gravity="center"
        android:text="Upgrade to Premium"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_limit_message" />

    <TextView
        android:id="@+id/btn_close_limit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:padding="8dp"
        android:text="Maybe Later"
        android:textColor="#8C98A4"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_upgrade_premium" />

</androidx.constraintlayout.widget.ConstraintLayout>
