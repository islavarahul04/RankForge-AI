<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_white_card"
    android:elevation="2dp"
    android:padding="16dp">

    <ImageView
        android:id="@+id/iv_test_icon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_circle_profile"
        android:backgroundTint="#F0F2F5"
        android:padding="12dp"
        android:src="@drawable/ic_tests_doc"
        app:tint="#5A6B80"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_test_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Full Mock Test"
        android:textColor="#101820"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_test_icon"
        app:layout_constraintTop_toTopOf="@id/iv_test_icon" />

    <TextView
        android:id="@+id/tv_test_date"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:text="Attempted Date"
        android:textColor="#8C98A4"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_test_icon"
        app:layout_constraintTop_toBottomOf="@id/tv_test_title" />

    <View
        android:id="@+id/divider_history"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="#F0F2F5"
        app:layout_constraintTop_toBottomOf="@id/iv_test_icon" />

    <!-- Score Container -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider_history">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Score"
            android:textColor="#8C98A4"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="0 / 200"
            android:textColor="#101820"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_view_result_history"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_outline_button"
        android:backgroundTint="#F8F9FE"
        android:paddingHorizontal="16dp"
        android:text="View Result"
        android:textAllCaps="false"
        android:textColor="#3B82F6"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider_history" />

</androidx.constraintlayout.widget.ConstraintLayout>
