<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#26348B"
    tools:context=".AdminDashboardActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="48dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Admin Dashboard"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Welcome back, Admin"
                        android:textColor="#D0D5FF"
                        android:textSize="14sp" />
                </LinearLayout>
                
                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_circle_icon"
                    android:backgroundTint="#4255A4"
                    android:gravity="center"
                    android:text="AD"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Cards Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:columnCount="2"
                android:useDefaultMargins="true"
                android:alignmentMode="alignBounds">

                <!-- Users -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_glass_button"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_group_users"
                            app:tint="#D0D5FF" />
                        <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                        <TextView
                            android:id="@+id/tv_users_percentage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_green"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"
                            android:text="+12%"
                            android:textColor="#4CAF50"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    
                    <TextView
                        android:id="@+id/tv_total_users"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Users"
                        android:textColor="#D0D5FF"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Active -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_glass_button"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_activity_pulse"
                            app:tint="#4CAF50" />
                        <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                        <TextView
                            android:id="@+id/tv_active_percentage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_green"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"
                            android:text="+5%"
                            android:textColor="#4CAF50"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    
                    <TextView
                        android:id="@+id/tv_active_today"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active Today"
                        android:textColor="#D0D5FF"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Revenue -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_glass_button"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹"
                            android:textColor="#FFEB3B"
                            android:textSize="20sp"
                            android:textStyle="bold"/>
                        <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                        <TextView
                            android:id="@+id/tv_revenue_percentage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_green"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"
                            android:text="+18%"
                            android:textColor="#4CAF50"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    
                    <TextView
                        android:id="@+id/tv_revenue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="₹0"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Revenue"
                        android:textColor="#D0D5FF"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Tests -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_glass_button"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_tests_doc"
                            app:tint="#F48FB1" />
                        <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                        <TextView
                            android:id="@+id/tv_tests_percentage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_green"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"
                            android:text="+8%"
                            android:textColor="#4CAF50"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    
                    <TextView
                        android:id="@+id/tv_tests_taken"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tests Taken"
                        android:textColor="#D0D5FF"
                        android:textSize="12sp" />
                </LinearLayout>

            </GridLayout>

            <!-- Quick Actions -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Quick Actions"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <!-- Action 1 -->
                    <LinearLayout
                        android:id="@+id/btn_add_user_action"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_circle_icon"
                            android:backgroundTint="#1AFFFFFF"
                            android:padding="16dp"
                            android:src="@drawable/ic_add_user"
                            app:tint="#FFFFFF" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Add User"
                            android:textColor="#D0D5FF"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <!-- Action 2 -->
                    <LinearLayout
                        android:id="@+id/btn_upload_content_action"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_circle_icon"
                            android:backgroundTint="#1AFFFFFF"
                            android:padding="16dp"
                            android:src="@drawable/ic_upload_content"
                            app:tint="#FFFFFF" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Upload Content"
                            android:textColor="#D0D5FF"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <!-- Action 3 -->
                    <LinearLayout
                        android:id="@+id/btn_view_reports_action"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_circle_icon"
                            android:backgroundTint="#1AFFFFFF"
                            android:padding="16dp"
                            android:src="@drawable/ic_view_reports"
                            app:tint="#FFFFFF" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="View Reports"
                            android:textColor="#D0D5FF"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <!-- Action 4 -->
                    <LinearLayout
                        android:id="@+id/btn_send_alert_action"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_circle_icon"
                            android:backgroundTint="#1AFFFFFF"
                            android:padding="16dp"
                            android:src="@drawable/ic_send_alert"
                            app:tint="#FFFFFF" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Send Alert"
                            android:textColor="#D0D5FF"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <!-- Action 6: Manage PYQ -->
                    <LinearLayout
                        android:id="@+id/btn_manage_pyq_action"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_circle_icon"
                            android:backgroundTint="#1AFFFFFF"
                            android:padding="16dp"
                            android:src="@drawable/ic_view_reports"
                            app:tint="#FFFFFF" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Manage PYQ"
                            android:textColor="#D0D5FF"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <!-- Action 7: Support Tickets -->
                    <LinearLayout
                        android:id="@+id/btn_support_tickets_action"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_circle_icon"
                            android:backgroundTint="#1AFFFFFF"
                            android:padding="16dp"
                            android:src="@drawable/ic_info_outline"
                            app:tint="#FFFFFF" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Support"
                            android:textColor="#D0D5FF"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <!-- Action 8: Manage Subscriptions -->
                    <LinearLayout
                        android:id="@+id/btn_manage_subscriptions_action"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_circle_icon"
                            android:backgroundTint="#1AFFFFFF"
                            android:padding="16dp"
                            android:src="@drawable/ic_rs"
                            app:tint="#FFEB3B" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Subscriptions"
                            android:textColor="#D0D5FF"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <!-- Action 9: Manage Study -->
                    <LinearLayout
                        android:id="@+id/btn_manage_study_action"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_circle_icon"
                            android:backgroundTint="#1AFFFFFF"
                            android:padding="16dp"
                            android:src="@drawable/ic_book_open"
                            app:tint="#4CAF50" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Study Content"
                            android:textColor="#D0D5FF"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <!-- Spacer -->
                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Recent Activity -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Recent Activity"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Recent Activity container -->
            <LinearLayout
                android:id="@+id/ll_recent_activity_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">
                
                <TextView
                    android:id="@+id/tv_empty_activity"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:gravity="center"
                    android:text="No recent activity data available."
                    android:textColor="#D0D5FF"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
