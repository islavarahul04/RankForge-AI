<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".AdminSendAlertActivity">

    <!-- Header Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_circle_icon"
            android:backgroundTint="#F0F4F8"
            android:padding="8dp"
            android:src="@drawable/ic_chevron_left"
            app:tint="#26348B"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Send Notification"
            android:textColor="#26348B"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="40dp">

            <!-- Notification Type Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Type of Notification"
                android:textColor="#26348B"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- RadioGroup for Types -->
            <RadioGroup
                android:id="@+id/rg_notification_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rb_tests"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:paddingHorizontal="8dp"
                    android:text="Tests"
                    android:textColor="#101820"
                    android:textSize="14sp"
                    android:buttonTint="#FF8C00"/>

                <RadioButton
                    android:id="@+id/rb_study"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:paddingHorizontal="8dp"
                    android:text="Study"
                    android:textColor="#101820"
                    android:textSize="14sp"
                    android:buttonTint="#FF8C00"/>

                <RadioButton
                    android:id="@+id/rb_community"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:paddingHorizontal="8dp"
                    android:text="Community"
                    android:textColor="#101820"
                    android:textSize="14sp"
                    android:buttonTint="#FF8C00"/>

                <RadioButton
                    android:id="@+id/rb_offers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:paddingHorizontal="8dp"
                    android:text="Offers"
                    android:textColor="#101820"
                    android:textSize="14sp"
                    android:buttonTint="#FF8C00"/>
            </RadioGroup>

            <!-- Message Content Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Content"
                android:textColor="#26348B"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_notification_content"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_light_purple_card"
                android:backgroundTint="#F0F4F8"
                android:gravity="top|start"
                android:hint="Write your notification message here..."
                android:inputType="textMultiLine"
                android:padding="16dp"
                android:textColor="#101820"
                android:textColorHint="#8C98A4"
                android:textSize="14sp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="40dp" />

            <!-- Send Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_send_notification"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_pill_orange"
                android:text="Send  ➔"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
