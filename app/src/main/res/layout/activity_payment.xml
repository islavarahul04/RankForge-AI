<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FE"
    tools:context=".PaymentActivity">

    <!-- Top Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_section"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="24dp"
            android:background="@drawable/bg_circle_profile"
            android:backgroundTint="#F0F2F5"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#101820"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Payment"
            android:textColor="#101820"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:paddingBottom="140dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_section">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Plan Summary Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_white_card"
                android:elevation="2dp"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_plan_summary_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Pro Plan — Monthly"
                    android:textColor="#101820"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_plan_summary_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="₹299"
                    android:textColor="#101820"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_plan_summary_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    tools:text="First 7 days free, then ₹299/month"
                    android:textColor="#8C98A4"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_plan_summary_name" />

                <!-- Free trial badge -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_plan_summary_desc">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_check_circle"
                        app:tint="#4CAF50"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="7-Day Free Trial Applied"
                        android:textColor="#4CAF50"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Select Payment Method"
                android:textColor="#101820"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- UPI Payment Method -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_upi_method"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_orange_border_card"
                android:elevation="4dp"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iv_upi_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_orange_translucent_card"
                    android:padding="6dp"
                    android:src="@drawable/ic_lock"
                    app:tint="#FF8C00"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_upi_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Pay via UPI"
                    android:textColor="#101820"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@id/iv_upi_radio"
                    app:layout_constraintStart_toEndOf="@id/iv_upi_icon"
                    app:layout_constraintTop_toTopOf="@id/iv_upi_icon" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Google Pay, PhonePe, Paytm"
                    android:textColor="#8C98A4"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toStartOf="@id/iv_upi_radio"
                    app:layout_constraintStart_toEndOf="@id/iv_upi_icon"
                    app:layout_constraintTop_toBottomOf="@id/tv_upi_title" />

                <ImageView
                    android:id="@+id/iv_upi_radio"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check_circle"
                    app:tint="#FF8C00"
                    app:layout_constraintBottom_toBottomOf="@id/iv_upi_icon"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/iv_upi_icon" />

                <!-- UPI Input inside the card -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:layout_constraintTop_toBottomOf="@id/iv_upi_icon">
                    
                    <EditText
                        android:id="@+id/et_upi_id"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_search_bar"
                        android:backgroundTint="#F0F2F5"
                        android:hint="username@upi"
                        android:textColor="#101820"
                        android:textColorHint="#8C98A4"
                        android:textSize="14sp"
                        android:paddingHorizontal="16dp"
                        app:layout_constraintEnd_toStartOf="@id/btn_verify_upi"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_verify_upi"
                        android:layout_width="90dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_button_solve"
                        android:backgroundTint="#101820"
                        android:text="Verify"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                        
                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Credit / Debit Method -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_card_method"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_white_card"
                android:elevation="2dp"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iv_card_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_circle_profile"
                    android:backgroundTint="#F0F2F5"
                    android:padding="6dp"
                    android:src="@drawable/ic_credit_card_outline"
                    app:tint="#5A6B80"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_card_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Credit / Debit Card"
                    android:textColor="#101820"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@id/iv_card_radio"
                    app:layout_constraintStart_toEndOf="@id/iv_card_icon"
                    app:layout_constraintTop_toTopOf="@id/iv_card_icon" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Visa, Mastercard, Rupay"
                    android:textColor="#8C98A4"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toStartOf="@id/iv_card_radio"
                    app:layout_constraintStart_toEndOf="@id/iv_card_icon"
                    app:layout_constraintTop_toBottomOf="@id/tv_card_title" />

                <ImageView
                    android:id="@+id/iv_card_radio"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_circle_outline"
                    app:tint="#D0D5FF"
                    app:layout_constraintBottom_toBottomOf="@id/iv_card_icon"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/iv_card_icon" />

                <!-- Card Details Input -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_card_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@id/iv_card_icon">
                    
                    <EditText
                        android:id="@+id/et_card_name"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_search_bar"
                        android:backgroundTint="#F0F2F5"
                        android:hint="Name on Card"
                        android:textColor="#101820"
                        android:textColorHint="#8C98A4"
                        android:textSize="14sp"
                        android:paddingHorizontal="16dp"
                        app:layout_constraintTop_toTopOf="parent" />

                    <EditText
                        android:id="@+id/et_card_number"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_search_bar"
                        android:backgroundTint="#F0F2F5"
                        android:hint="Card Number"
                        android:inputType="number"
                        android:textColor="#101820"
                        android:textColorHint="#8C98A4"
                        android:textSize="14sp"
                        android:paddingHorizontal="16dp"
                        app:layout_constraintTop_toBottomOf="@id/et_card_name" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toBottomOf="@id/et_card_number">
                        
                        <EditText
                            android:id="@+id/et_card_expiry"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_search_bar"
                            android:backgroundTint="#F0F2F5"
                            android:hint="MM/YY"
                            android:textColor="#101820"
                            android:textColorHint="#8C98A4"
                            android:textSize="14sp"
                            android:paddingHorizontal="16dp" />
                            
                        <EditText
                            android:id="@+id/et_card_cvv"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_search_bar"
                            android:backgroundTint="#F0F2F5"
                            android:hint="CVV"
                            android:inputType="numberPassword"
                            android:maxLength="4"
                            android:textColor="#101820"
                            android:textColorHint="#8C98A4"
                            android:textSize="14sp"
                            android:paddingHorizontal="16dp" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
            
            <!-- Net Banking Method -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_bank_method"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_white_card"
                android:elevation="2dp"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iv_bank_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_circle_profile"
                    android:backgroundTint="#F0F2F5"
                    android:padding="6dp"
                    android:src="@drawable/ic_refer_crown"
                    app:tint="#5A6B80"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_bank_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Net Banking"
                    android:textColor="#101820"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/iv_bank_radio"
                    app:layout_constraintStart_toEndOf="@id/iv_bank_icon"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/iv_bank_radio"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_circle_outline"
                    app:tint="#D0D5FF"
                    app:layout_constraintBottom_toBottomOf="@id/iv_bank_icon"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/iv_bank_icon" />

                <!-- Net Banking Input -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_bank_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@id/iv_bank_icon">

                    <Spinner
                        android:id="@+id/spinner_bank_name"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_search_bar"
                        android:backgroundTint="#F0F2F5"
                        android:paddingHorizontal="16dp"
                        app:layout_constraintTop_toTopOf="parent" />
                        
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_proceed_bank"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_button_solve"
                        android:backgroundTint="#101820"
                        android:paddingHorizontal="24dp"
                        android:text="Proceed"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/spinner_bank_name" />
                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Fixed Bottom Billing Summary -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tv_subtotal_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subtotal"
            android:textColor="#8C98A4"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_subtotal_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="₹299.00"
            android:textColor="#101820"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_subtotal_label" />

        <TextView
            android:id="@+id/tv_gst_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="GST (18%)"
            android:textColor="#8C98A4"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_subtotal_label" />

        <TextView
            android:id="@+id/tv_gst_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="₹53.82"
            android:textColor="#101820"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_gst_label" />

        <View
            android:id="@+id/divider_total"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="#F0F2F5"
            app:layout_constraintTop_toBottomOf="@id/tv_gst_label" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_pay_now"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_button_solve"
            android:backgroundTint="#FF8C00"
            tools:text="Pay ₹352.82 Security"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/divider_total" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
